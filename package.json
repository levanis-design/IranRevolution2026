    "scrape-telegram": "npx tsx --env-file=.env scripts/scrape_telegram_range.ts",
    "admin-review": "npx tsx --env-file=.env scripts/admin_review_agent.ts",
    "verify-rtn": "npx tsx --env-file=.env scripts/batch_verify_rtn.ts",
    "scrape-iranvictims": "npx tsx --env-file=.env scripts/scrapers/iranvictims_csv.ts",
    "verify-iranvictims": "npx tsx --env-file=.env scripts/batch_verify_iranvictims.ts",
    "triage-reports": "npx tsx --env-file=.env scripts/triage_reports.ts",
    "sync-images": "npx tsx --env-file=.env scripts/sync_images.ts"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^25.0.8",
