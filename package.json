    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "form-data": "^4.0.5",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.0.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide": "^0.562.0",
    "node-fetch": "^3.3.2",
    "qrcode": "^1.5.4"
  }
